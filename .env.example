LISTEN_ADDR=127.0.0.1:8080
DATABASE_PATH=./data/api.sqlite
DEFAULT_COUNTRY=LAT
UPSTREAM_LANGUAGE=1
UPSTREAM_TIMEOUT=15s
UPSTREAM_MAX_CONCURRENCY=2
UPSTREAM_MIN_INTERVAL=750ms
UPSTREAM_MAX_BODY_BYTES=5242880
CACHE_SEARCH_TTL=10m
CACHE_ACTIVE_STANDINGS_TTL=2m
CACHE_COMPLETED_TTL=24h
MAX_STALE_ACTIVE=24h
MAX_STALE_COMPLETED=720h
MAX_SEARCH_INTERVAL_DAYS=366
MAX_SEARCH_RESULTS=500
CACHE_CONTROL_MAX_AGE=30
LOG_LEVEL=info
LOG_FORMAT=json
API_KEYS=
CORS_ALLOWED_ORIGINS=https://alexzavalny.github.io,http://localhost:8000,http://127.0.0.1:8000
# Required only to bind publicly without API_KEYS. Unsafe for internet exposure.
ALLOW_INSECURE_PUBLIC_BIND=false
